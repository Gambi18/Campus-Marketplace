# Root environment for Docker Compose. Copy to `.env` (compose reads it
# automatically) and adjust as needed:  cp .env.example .env
#
# Every value here has a built-in default in docker-compose.yml, so the stack
# runs with no .env at all — this file is for overriding those defaults.

# --- Database ---------------------------------------------------------------
DB_USER=marketplace
DB_PASSWORD=password
DB_NAME=campus_marketplace
DB_PORT=5432

# --- Backend ----------------------------------------------------------------
ENV=development
BACKEND_PORT=8080
# REQUIRED in real deployments — use a long random string. The server refuses to
# start if this is empty or left as the example placeholder.
JWT_SECRET=dev-only-insecure-change-me
ALLOWED_ORIGINS=http://localhost:3000

# Platform admin seeded on first startup (when the admins table is empty).
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@campusmarket.local
ADMIN_PASSWORD=password

# One-time admin bootstrap secret for POST /api/v1/admin/create (sent in the
# X-Admin-Bootstrap-Token header). Only works while no admin exists. Leave empty
# to disable the HTTP bootstrap and rely solely on the seed above.
ADMIN_BOOTSTRAP_TOKEN=

# Testing only — simulate payments without real CamPay calls. Ignored when
# ENV=production. Never enable in a real deployment.
DEV_BYPASS_PAYMENT=false

# Optional integrations (uploads fall back to local disk if Cloudinary is unset).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CAMPAY_BASE_URL=https://demo.campay.net/api
CAMPAY_APP_USERNAME=
CAMPAY_APP_PASSWORD=
CAMPAY_PERMANENT_TOKEN=

# --- Frontend ---------------------------------------------------------------
FRONTEND_PORT=3000
# Baked into the browser bundle at build time. Must be reachable from the
# browser (the host), so use localhost + the published backend port, NOT the
# internal docker service name. Change the host if deploying remotely.
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080
