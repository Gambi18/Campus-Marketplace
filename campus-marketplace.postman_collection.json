          },
          "response": [
            {
              "name": "201 Created",
              "code": 201,
              "body": "{\n  \"id\": \"uuid\",\n  \"username\": \"admin\",\n  \"email\": \"admin@campus.edu\",\n  \"created_at\": \"2026-06-17 12:00:00 +0000 UTC\"\n}"
            }
          ]
        },
        {
          "name": "POST /api/v1/admin/auth/login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@campus.edu\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admin/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "auth", "login"]
            },
            "description": "Login as an admin. Returns a separate admin JWT."
          },
          "response": [
            {
              "name": "200 OK",
              "code": 200,
              "body": "{\n  \"token\": \"admin_jwt_token_here\",\n  \"admin\": {\n    \"id\": \"uuid\",\n    \"username\": \"admin\",\n    \"email\": \"admin@campus.edu\",\n    \"created_at\": \"2026-06-17 12:00:00 +0000 UTC\"\n  }\n}"
            }
          ]
        }
      ]
    },
