{
  "info": {
    "name": "Campus Marketplace API",
    "description": "Full API collection for Campus Marketplace — a peer-to-peer student marketplace with escrow payments.\n\nBase URL: http://localhost:8080\n\nAuth: student JWT via POST /api/v1/auth/login → use the `token` in Authorization: Bearer header.\nAdmin auth: separate POST /api/v1/admin/auth/login → admin token.\n\nStudent ID file upload is required for registration.\nProduct images are uploaded as multipart/form-data fields (image_1 required, image_2-4 optional).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "opencode"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          },
          "response": [
            {
              "name": "OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"ok\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Auth (Student)",
      "item": [
        {
          "name": "POST /api/v1/auth/register",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "username", "value": "john_doe", "type": "text" },
                { "key": "email", "value": "john@university.edu", "type": "text" },
                { "key": "password", "value": "secret123", "type": "text" },
                { "key": "full_name", "value": "John Doe", "type": "text" },
                { "key": "student_id", "value": "", "type": "file", "src": "" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "Register a new student account. Requires a student ID image/PDF file."
          },
          "response": [
            {
              "name": "201 Created",
              "code": 201,
              "body": "{\n  \"message\": \"registration successful, please come back after 24 hours for verification\",\n  \"user\": {\n    \"id\": \"uuid\",\n    \"full_name\": \"John Doe\",\n    \"username\": \"john_doe\",\n    \"email\": \"john@university.edu\",\n    \"is_verified\": false,\n    \"account_status\": \"pending\",\n    \"student_id_url\": \"https://res.cloudinary.com/.../student-ids/...\"\n  }\n}"
            }
          ]
        },
        {
          "name": "POST /api/v1/auth/login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@university.edu\",\n  \"password\": \"secret123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Login as a student. Returns a JWT token to use in Authorisation: Bearer header."
          },
          "response": [
            {
              "name": "200 OK",
              "code": 200,
              "body": "{\n  \"token\": \"jwt_token_here\",\n  \"user\": {\n    \"id\": \"uuid\",\n    \"full_name\": \"John Doe\",\n    \"username\": \"john_doe\",\n    \"email\": \"john@university.edu\",\n    \"is_verified\": false,\n    \"account_status\": \"approved\"\n  }\n}"
            },
            {
              "name": "403 Forbidden (pending)",
              "code": 403,
              "body": "{\n  \"error\": \"your account is pending verification, please check back after 24 hours\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Auth (Admin)",
      "item": [
