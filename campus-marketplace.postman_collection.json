    {
      "name": "Student — Messaging",
      "item": [
        {
          "name": "GET /api/v1/conversations",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{student_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/conversations",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "conversations"]
            },
            "description": "Get all conversations for the authenticated user. Filters out unpaid conversations (unless DEV_BYPASS_PAYMENT=true). Each conversation includes other_user_id / other_user_name (the partner) and unread_count (number of unread messages from the partner, used for the per-conversation badge)."
          },
          "response": [
            {
              "name": "200 OK",
              "code": 200,
              "body": "{\n  \"conversations\": [\n    {\n      \"id\": \"uuid\",\n      \"sender_id\": \"uuid\",\n      \"sender_name\": \"Alice\",\n      \"receiver_id\": \"uuid\",\n      \"other_user_id\": \"uuid\",\n      \"other_user_name\": \"Alice\",\n      \"product_id\": \"uuid\",\n      \"product_title\": \"MacBook Air\",\n      \"product_image\": \"https://...\",\n      \"content\": \"Last message text\",\n      \"is_read\": false,\n      \"unread_count\": 2,\n      \"created_at\": \"...\"\n    }\n  ],\n  \"count\": 1\n}"
            }
          ]
        },
        {
          "name": "GET /api/v1/conversations/:product_id/:user_id",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{student_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/conversations/{{product_id}}/{{other_user_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "conversations", "{{product_id}}", "{{other_user_id}}"]
            },
            "description": "Get all messages in a conversation between the authenticated user and another user for a specific product."
          },
          "response": [
            {
              "name": "200 OK",
              "code": 200,
              "body": "{\n  \"messages\": [\n    {\n      \"id\": \"uuid\",\n      \"sender_id\": \"uuid\",\n      \"sender_name\": \"Alice\",\n      \"receiver_id\": \"uuid\",\n      \"product_id\": \"uuid\",\n      \"content\": \"Hey, is this still available?\",\n      \"is_read\": true,\n      \"created_at\": \"...\"\n    }\n  ],\n  \"count\": 2\n}"
            }
          ]
        },
        {
          "name": "GET /api/v1/unread-count",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{student_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/unread-count",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "unread-count"]
            },
            "description": "Get total unread message count across all conversations."
          },
          "response": [
            {
              "name": "200 OK",
              "code": 200,
              "body": "{\n  \"unread_count\": 3\n}"
            }
          ]
        },
        {
          "name": "WS /api/v1/ws (WebSocket)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{student_token}}" }
            ],
            "url": {
              "raw": "ws://localhost:8080/api/v1/ws",
              "host": ["ws://localhost:8080"],
              "path": ["api", "v1", "ws"]
            },
            "description": "WebSocket endpoint for real-time messaging. Connect with the student JWT as a query param or header. Send JSON: { \"type\": \"chat\", \"receiver_id\": \"uuid\", \"product_id\": \"uuid\", \"content\": \"message text\" }"
          }
        }
      ]
    },
    {
      "name": "Student — Payments",
      "item": [
        {
          "name": "POST /api/v1/payments/initiate",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{student_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_id\": \"uuid-here\",\n  \"phone_number\": \"237650000000\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/payments/initiate",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "payments", "initiate"]
            },
            "description": "Initiate payment for pay-to-chat. Buyer enters their MTN/Orange phone number. Triggers CamPay USSD prompt."
          },
          "response": [
            {
              "name": "200 OK",
              "code": 200,
              "body": "{\n  \"message\": \"payment initiated successfully, please confirm on your phone\",\n  \"reference\": \"campay_ref\",\n  \"payment\": {\n    \"id\": \"uuid\",\n    \"buyer_id\": \"uuid\",\n    \"seller_id\": \"uuid\",\n    \"product_id\": \"uuid\",\n    \"amount\": \"450000\",\n    \"phone_number\": \"237650000000\",\n    \"operator\": \"MTN\",\n    \"reference\": \"campay_ref\",\n    \"status\": \"pending\",\n    \"created_at\": \"...\"\n  }\n}"
            }
          ]
        },
        {
          "name": "GET /api/v1/payments/:id/status",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{student_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/payments/uuid-here/status",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "payments", "uuid-here", "status"]
            },
            "description": "Check payment status with CamPay. Auto-updates to 'held' if CamPay reports SUCCESSFUL."
          },
          "response": [
            {
              "name": "200 OK",
              "code": 200,
              "body": "{\n  \"payment_id\": \"uuid\",\n  \"reference\": \"campay_ref\",\n  \"status\": \"SUCCESSFUL\",\n  \"amount\": \"450000\",\n  \"operator\": \"MTN\"\n}"
            }
          ]
        },
        {
          "name": "POST /api/v1/payments/:id/confirm",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{student_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/payments/uuid-here/confirm",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "payments", "uuid-here", "confirm"]
            },
            "description": "Buyer confirms delivery. Releases payment to seller (minus 3% fee). Generates PDF receipt."
          },
          "response": [
            {
              "name": "200 OK",
              "code": 200,
              "body": "{\n  \"message\": \"delivery confirmed, payment released to seller\",\n  \"receipt_number\": \"CM-2026-000001\",\n  \"receipt_url\": \"https://res.cloudinary.com/...pdf\",\n  \"payment\": { ... }\n}"
            }
          ]
        },
        {
          "name": "POST /api/v1/payments/:id/reject",
          "request": {
            "method": "POST",
            "header": [
