PORT=8080
ENV=development
LOG_LEVEL=info

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=Admin
DB_PASSWORD=password
DB_NAME=campus_marketplace
DB_SSLMODE=disable
# Set to "require" in production for TLS-encrypted database connections

# JWT — REQUIRED. The server refuses to start if this is empty or left as the
# example value below. Use a long random string in any real environment.
JWT_SECRET=change-me-to-a-long-random-secret

# CORS / WebSocket — comma-separated list of allowed browser origins.
ALLOWED_ORIGINS=http://localhost:3000

# Platform admin (seeded on first startup when admins table is empty)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@campusmarket.local
ADMIN_PASSWORD=password

# One-time admin bootstrap secret. When set, POST /api/v1/admin/create accepts a
# request carrying this value in the X-Admin-Bootstrap-Token header — but ONLY
# while the admins table is empty. Once any admin exists the endpoint is inert.
# Leave empty to disable the HTTP bootstrap entirely (rely on the seed above).
ADMIN_BOOTSTRAP_TOKEN=

# Cloudinary (optional — if unset, uploads fall back to local ./uploads disk)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# API
API_TIMEOUT=30s

# CamPay payments
CAMPAY_BASE_URL=https://demo.campay.net/api
CAMPAY_APP_USERNAME=your_username
CAMPAY_APP_PASSWORD=your_password
CAMPAY_PERMANENT_TOKEN=your_permanent_token_from_dashboard

# Testing only — when "true", payments are simulated (no real CamPay calls) so
# the chat flow can be exercised without money. Ignored entirely when ENV=production.
DEV_BYPASS_PAYMENT=false
